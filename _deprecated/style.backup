/* style.css */

body {
  font-family: Arial, sans-serif;
  text-align: center;
  padding: 20px;
  background-color: #fff;
  color: #333;
}

#quiz-container {
  margin: 20px auto;
  max-width: 600px;
  border: 1px solid #ddd;
  padding: 20px;
  background-color: #fafafa;
  box-shadow: 0 0 8px rgba(0,0,0,0.05);
  border-radius: 6px;
}

.option {
  margin: 10px auto;
  padding: 10px;
  border: 1px solid #ccc;
  cursor: pointer;
  max-width: 400px;
  user-select: none;
  border-radius: 4px;
  transition: background-color 0.3s ease;
}

.option:hover {
  background-color: #f0f0f0;
}

.correct {
  background-color: #d4edda !important;
  border-color: #28a745 !important;
  color: #155724;
  font-weight: bold;
}

.incorrect {
  background-color: #f8d7da !important;
  border-color: #dc3545 !important;
  color: #721c24;
  font-weight: bold;
}

.bubble {
  display: inline-block;
  padding: 10px;
  margin: 5px;
  background-color: #e0e0e0;
  border-radius: 20px;
  cursor: pointer;
  font-size: 1.2em;
  user-select: none;
}

.bubble:hover {
  background-color: #d0d0d0;
}

#answer-box {
  min-height: 40px;
  margin: 10px 0;
  font-size: 1.5em;
  border-bottom: 2px solid #ccc;
}

#score {
  font-size: 1.2em;
  margin-top: 20px;
  font-weight: 600;
}

#save-load-container {
  margin: 20px auto;
  max-width: 600px;
  border: 1px solid #ddd;
  padding: 15px;
  background: #f9f9f9;
  border-radius: 6px;
  box-shadow: 0 0 8px rgba(0,0,0,0.05);
}

#save-load-container label {
  font-weight: 600;
  margin-right: 10px;
}

#save-load-container input[type="text"] {
  width: 200px;
  padding: 5px 8px;
  font-size: 1em;
  border: 1px solid #ccc;
  border-radius: 4px;
  vertical-align: middle;
}

#save-load-container button {
  padding: 6px 12px;
  margin-left: 5px;
  font-size: 1em;
  cursor: pointer;
  border: none;
  background-color: #007bff;
  color: white;
  border-radius: 4px;
  transition: background-color 0.3s ease;
  vertical-align: middle;
}

#save-load-container button:hover {
  background-color: #0056b3;
}

#next-btn {
  margin-top: 20px;
  padding: 8px 20px;
  font-size: 1.1em;
  cursor: pointer;
  border: none;
  background-color: #28a745;
  color: white;
  border-radius: 6px;
  transition: background-color 0.3s ease;
}

#next-btn:hover {
  background-color: #218838;
}
